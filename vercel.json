{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/",
      "destination": "/ar",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/login",
      "destination": "/ar/login"
    },
    {
      "source": "/:path((?!ar$)(?!en$)(?!_next)(?!_vercel)(?!.*\\..*).*)",
      "destination": "/ar/:path"
    }
  ]
}
